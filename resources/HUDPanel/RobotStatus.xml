<?xml version="1.0" encoding="UTF-8"?>
<HUDPanel id="robot-status">
  <title>本车状态</title>
  <description>显示机器人血量、弹药、电容等实时状态</description>
  
  <!-- 初始位置配置 - 左下角 -->
  <position>
    <bottom>60px</bottom>
    <left>20px</left>
  </position>
  
  <!-- 初始大小配置 -->
  <size>
    <width>580px</width>
    <height>auto</height>
    <minWidth>380px</minWidth>
    <minHeight>130px</minHeight>
    <maxWidth>900px</maxWidth>
    <maxHeight>300px</maxHeight>
  </size>
  
  <!-- 功能配置 -->
  <options>
    <resizable>true</resizable>
    <defaultTeam>inherit</defaultTeam>
    <hideTitleBar>true</hideTitleBar>
    <transparent>true</transparent>
    <defaultVisible>true</defaultVisible>
  </options>
  
  <!-- 显示内容配置 -->
  <content>
    <component>RobotStateManager</component>
    <props>
      <enableSimulation>true</enableSimulation>
    </props>
  </content>
</HUDPanel>
