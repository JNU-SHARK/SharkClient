<?xml version="1.0" encoding="UTF-8"?>
<VehiclePhysics id="sentry" name="哨兵机器人">
  <!-- 基础属性 -->
  <Base>
    <mass>12.0</mass> <!-- kg，轻量化 -->
    <chassisSize width="0.40" height="0.15" length="0.5"/> <!-- m，紧凑设计 -->
    <description>哨兵机器人，快速反应型</description>
  </Base>
  
  <!-- 电机参数 -->
  <Motor>
    <power>100</power> <!-- W，中等功率 -->
    <torque>0.4</torque> <!-- Nm -->
    <maxRPM>7000</maxRPM> <!-- 高转速 -->
    <powerPercent>45</powerPercent>
  </Motor>
  
  <!-- 悬挂系统 -->
  <Suspension>
    <stiffness>18.0</stiffness> <!-- 适中刚度 -->
    <damping>2.0</damping>
    <compression>4.0</compression>
    <restLength>0.08</restLength>
    <maxTravel>0.04</maxTravel>
  </Suspension>
  
  <!-- 轮胎参数 -->
  <Wheels>
    <radius>0.055</radius> <!-- m，稍小轮子 -->
    <friction>900.0</friction>
    <rollInfluence>0.12</rollInfluence>
  </Wheels>
  
  <!-- 运动阻尼 -->
  <Damping>
    <linear>0.18</linear> <!-- 低阻尼，快速响应 -->
    <angular>0.45</angular>
  </Damping>
  
  <!-- 控制参数 -->
  <Control>
    <turnSensitivity>60</turnSensitivity> <!-- 高灵敏度 -->
    <maxSpeed>3.5</maxSpeed> <!-- m/s，较快 -->
  </Control>
  
  <!-- 云台限制 -->
  <Gimbal>
    <yawMin>-180</yawMin>
    <yawMax>180</yawMax>
    <pitchMin>-35</pitchMin> <!-- 更大俯仰角 -->
    <pitchMax>35</pitchMax>
    <rollMin>0</rollMin>
    <rollMax>0</rollMax>
    <mouseSensitivity>0.0025</mouseSensitivity> <!-- 高灵敏度 -->
  </Gimbal>
</VehiclePhysics>
