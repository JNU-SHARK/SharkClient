<?xml version="1.0" encoding="UTF-8"?>
<VehiclePhysics id="drone" name="空中机器人">
  <!-- 基础属性 -->
  <Base>
    <mass>3.0</mass> <!-- kg，超轻量 -->
    <chassisSize width="0.25" height="0.08" length="0.30"/> <!-- m，紧凑 -->
    <description>空中机器人（地面模式），极速配置</description>
  </Base>
  
  <!-- 电机参数 -->
  <Motor>
    <power>60</power> <!-- W，小功率 -->
    <torque>0.2</torque> <!-- Nm，小扭矩 -->
    <maxRPM>8000</maxRPM> <!-- 极高转速 -->
    <powerPercent>40</powerPercent>
  </Motor>
  
  <!-- 悬挂系统 -->
  <Suspension>
    <stiffness>12.0</stiffness> <!-- 软悬挂 -->
    <damping>1.5</damping>
    <compression>3.0</compression>
    <restLength>0.06</restLength>
    <maxTravel>0.03</maxTravel>
  </Suspension>
  
  <!-- 轮胎参数 -->
  <Wheels>
    <radius>0.04</radius> <!-- m，小轮子 -->
    <friction>700.0</friction>
    <rollInfluence>0.15</rollInfluence>
  </Wheels>
  
  <!-- 运动阻尼 -->
  <Damping>
    <linear>0.15</linear> <!-- 极低阻尼 -->
    <angular>0.35</angular>
  </Damping>
  
  <!-- 控制参数 -->
  <Control>
    <turnSensitivity>70</turnSensitivity> <!-- 极高灵敏度 -->
    <maxSpeed>4.5</maxSpeed> <!-- m/s，极速 -->
  </Control>
  
  <!-- 云台限制 -->
  <Gimbal>
    <yawMin>-180</yawMin>
    <yawMax>180</yawMax>
    <pitchMin>-45</pitchMin> <!-- 大俯仰角 -->
    <pitchMax>45</pitchMax>
    <rollMin>0</rollMin>
    <rollMax>0</rollMax>
    <mouseSensitivity>0.003</mouseSensitivity> <!-- 极高灵敏度 -->
  </Gimbal>
</VehiclePhysics>
